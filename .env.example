# Copy to .env for local runs:  copy .env.example .env
#
# Priority (who wins when the same key is set twice):
#   1) Process env (Docker compose `environment:`, 宝塔「环境变量」, systemd)
#   2) This .env file
# Set DOTENV_OVERRIDE=1 so THIS file wins over process env (recommended if you
# only manage secrets in .env).
#
# After editing .env you MUST restart the app (uvicorn / docker / 宝塔项目).

DOTENV_OVERRIDE=1

# --- Local / dev (weak admin allowed) ---
# Docker Compose no longer injects weak defaults; copy this file and keep
# ALLOW_INSECURE_ADMIN=1 only for local/dev.
ALLOW_INSECURE_ADMIN=1
ADMIN_PASSWORD=admin123
ADMIN_SECRET=dev-only-change-me-use-long-random

# --- Production example ---
# ALLOW_INSECURE_ADMIN=0
# ADMIN_PASSWORD=Str0ng-Passw0rd!
# ADMIN_SECRET=please-use-a-long-random-string-here

# Optional
CONVERT_CONCURRENCY=2
# MAX_UPLOAD_BYTES=52428800
# MAX_BATCH_FILES=20
# UPLOAD_RETENTION_DAYS=5
# UPLOAD_FILE_DIR=
# ADMIN_SESSION_TTL=43200
# ADMIN_COOKIE_SECURE=0

# Reverse proxy under a subpath only (e.g. https://example.com/toolkit/).
# Domain root proxy (https://tools.example.com/ -> uvicorn) must leave this empty.
# ROOT_PATH=/toolkit

# --- Async jobs / public rate limit ---
# JOBS_BACKEND=memory
# REDIS_URL=
# API_RATE_LIMIT=30
# API_RATE_WINDOW_SEC=60
# JOB_TTL_SEC=3600

# --- File express (取件码分享) ---
# EXPRESS_MAX_BYTES=52428800
# EXPRESS_DEFAULT_TTL_HOURS=24
# EXPRESS_MAX_TTL_HOURS=168
# EXPRESS_DIR=

