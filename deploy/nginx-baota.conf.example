#     proxy_pass http://127.0.0.1:8000/;   # 注意末尾斜杠：去掉前缀再转给应用
#     proxy_set_header Host $host;
#     proxy_set_header X-Forwarded-Proto $scheme;
#     proxy_set_header X-Forwarded-Prefix /toolkit;
# }
